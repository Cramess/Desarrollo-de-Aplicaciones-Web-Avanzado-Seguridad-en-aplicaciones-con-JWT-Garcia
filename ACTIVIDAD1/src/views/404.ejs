<%- include('partials/header') %>

<div style="min-height: 75vh; display: flex; align-items: center; justify-content: center; padding: 40px 20px;">
    <div style="text-align: center; max-width: 420px;">
        <div style="width: 96px; height: 96px; background: rgba(255, 149, 0, 0.15); border: 1px solid rgba(255, 149, 0, 0.3); border-radius: 28px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i class="material-icons" style="font-size: 3rem; color: #ff9500;">explore_off</i>
        </div>
        <p style="font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.3); text-transform: uppercase; letter-spacing: 0.12em; margin: 0 0 8px;">Error 404</p>
        <h1 style="font-size: 2.2rem; font-weight: 800; letter-spacing: -0.05em; margin: 0 0 12px;">Página No Encontrada</h1>
        <p style="font-size: 1rem; color: rgba(255, 255, 255, 0.45); line-height: 1.7; margin: 0 0 32px;">La ruta que buscas no existe o fue movida a otro lugar.</p>
        <a href="/"
            style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 16px; color: #fff; font-weight: 600; text-decoration: none; font-size: 0.95rem; transition: all 0.2s;"
            onmouseover="this.style.background='rgba(255,255,255,0.14)'"
            onmouseout="this.style.background='rgba(255,255,255,0.08)'">
            <i class="material-icons" style="font-size: 1.1rem;">home</i>
            Ir al inicio
        </a>
    </div>
</div>

<%- include('partials/footer') %>
