<%- include('partials/header') %>

<div style="padding: 24px 0 60px;">
    <div style="max-width: 560px; margin: 0 auto;">

        <!-- Header -->
        <div style="text-align: center; margin-bottom: 32px;">
            <div style="width: 72px; height: 72px; background: linear-gradient(145deg, #30d158, #0a84ff); border-radius: 22px; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 16px; box-shadow: 0 12px 30px rgba(48, 209, 88, 0.3);">
                <i class="material-icons" style="font-size: 2.2rem; color: #fff;">person_add</i>
            </div>
            <h1 style="font-size: 2rem; font-weight: 800; letter-spacing: -0.05em; margin: 0;">Crear cuenta</h1>
            <p style="color: rgba(255,255,255,0.45); margin: 6px 0 0; font-size: 0.95rem;">Rellena tus datos para registrarte</p>
        </div>

        <!-- Card -->
        <div style="background: rgba(28, 28, 32, 0.8); border: 1px solid rgba(255,255,255,0.1); border-radius: 28px; backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px); padding: 32px; box-shadow: 0 24px 60px rgba(0,0,0,0.5);">
            <form id="signUpForm">

                <!-- Sección: Datos personales -->
                <p style="font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px;">Datos personales</p>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px;">
                    <div>
                        <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Nombre</label>
                        <input id="name" type="text" required placeholder="Juan"
                            style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                            onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                            onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    </div>
                    <div>
                        <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Apellidos</label>
                        <input id="lastName" type="text" required placeholder="Pérez"
                            style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                            onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                            onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px;">
                    <div>
                        <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Teléfono</label>
                        <input id="phoneNumber" type="text" required placeholder="+51 999 999 999"
                            style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                            onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                            onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    </div>
                    <div>
                        <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Fecha de Nacimiento</label>
                        <input id="birthdate" type="date" required
                            style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:rgba(255,255,255,0.7);font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;color-scheme:dark;"
                            onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                            onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    </div>
                </div>

                <!-- Sección: Cuenta -->
                <p style="font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px;">Cuenta</p>

                <div style="margin-bottom: 12px;">
                    <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Email</label>
                    <input id="email" type="email" required placeholder="tu@email.com"
                        style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                        onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                        onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                </div>

                <div style="margin-bottom: 20px;">
                    <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Contraseña</label>
                    <input id="password" type="password" required placeholder="••••••••"
                        style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                        onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                        onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    <p style="font-size:0.78rem;color:rgba(255,255,255,0.3);margin:6px 0 0;">Mín. 8 caracteres, 1 mayúscula, 1 número y 1 especial (#$%&*@)</p>
                </div>

                <!-- Sección: Opcional -->
                <p style="font-size: 0.75rem; font-weight: 700; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 12px;">Opcional</p>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 28px;">
                    <div>
                        <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">URL de Perfil</label>
                        <input id="url_profile" type="text" placeholder="https://..."
                            style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                            onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                            onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    </div>
                    <div>
                        <label style="display:block;font-size:0.78rem;font-weight:600;color:rgba(255,255,255,0.5);margin-bottom:6px;">Dirección</label>
                        <input id="address" type="text" placeholder="Calle, Ciudad"
                            style="width:100%;box-sizing:border-box;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:12px 14px;color:#fff;font-size:0.95rem;outline:none;transition:all 0.25s;font-family:inherit;"
                            onfocus="this.style.borderColor='#0a84ff';this.style.background='rgba(10,132,255,0.1)'"
                            onblur="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(255,255,255,0.07)'">
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" id="submitBtn"
                    style="width:100%;padding:15px;background:linear-gradient(135deg,#30d158,#0a84ff);color:#fff;border:none;border-radius:16px;font-size:1rem;font-weight:700;cursor:pointer;letter-spacing:-0.01em;transition:all 0.2s ease;display:flex;align-items:center;justify-content:center;gap:8px;"
                    onmousedown="this.style.transform='scale(0.97)'"
                    onmouseup="this.style.transform='scale(1)'">
                    <i class="material-icons" style="font-size:1.1rem;">check_circle</i>
                    Crear cuenta
                </button>
            </form>

            <div style="height: 1px; background: rgba(255,255,255,0.1); margin: 22px 0;"></div>
            <a href="/signIn" style="display:block;text-align:center;color:rgba(255,255,255,0.5);font-size:0.9rem;text-decoration:none;">
                ¿Ya tienes cuenta? <span style="color:#0a84ff;font-weight:600;">Inicia sesión</span>
            </a>
        </div>
    </div>
</div>

<script>
    document.getElementById('signUpForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="material-icons" style="animation:spin 1s linear infinite;font-size:1.1rem;">refresh</i> Registrando...';

        const payload = {
            name: document.getElementById('name').value,
            lastName: document.getElementById('lastName').value,
            email: document.getElementById('email').value,
            password: document.getElementById('password').value,
            phoneNumber: document.getElementById('phoneNumber').value,
            birthdate: document.getElementById('birthdate').value,
            url_profile: document.getElementById('url_profile').value,
            address: document.getElementById('address').value
        };

        try {
            const response = await fetch('/api/auth/signUp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await response.json();

            if (response.ok) {
                M.toast({ html: '✅ Cuenta creada. Redirigiendo...', classes: 'rounded' });
                setTimeout(() => window.location.href = '/signIn', 1800);
            } else {
                M.toast({ html: data.message || 'Error en el registro', classes: 'rounded' });
                btn.disabled = false;
                btn.innerHTML = '<i class="material-icons" style="font-size:1.1rem;">check_circle</i> Crear cuenta';
            }
        } catch (error) {
            M.toast({ html: 'Error de conexión', classes: 'rounded' });
            btn.disabled = false;
            btn.innerHTML = '<i class="material-icons" style="font-size:1.1rem;">check_circle</i> Crear cuenta';
        }
    });
</script>
<style>
    @keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<%- include('partials/footer') %>
