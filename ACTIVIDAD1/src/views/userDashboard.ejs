<%- include('partials/header') %>

    <div style="padding: 24px 0 60px; max-width: 700px; margin: 0 auto;">

        <!-- Greeting hero -->
        <div
            style="background:linear-gradient(135deg,rgba(10,132,255,0.35),rgba(88,86,214,0.3));border:1px solid rgba(255,255,255,0.12);border-radius:28px;padding:36px 32px;margin-bottom:20px;backdrop-filter:blur(20px);">
            <p
                style="font-size:0.85rem;color:rgba(255,255,255,0.45);margin:0 0 4px;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">
                Dashboard</p>
            <h1 style="font-size:2.2rem;font-weight:800;letter-spacing:-0.05em;margin:0 0 10px;">Hola, bienvenido</h1>
            <p style="color:rgba(255,255,255,0.55);margin:0;font-size:1rem;line-height:1.6;">Aquí tienes acceso rápido a
                tu información y configuración de cuenta.</p>
        </div>

        <!-- Quick actions grid -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;">
            <a href="/profile"
                style="text-decoration:none;background:rgba(28,28,32,0.8);border:1px solid rgba(255,255,255,0.1);border-radius:22px;padding:24px;transition:all 0.2s;display:flex;flex-direction:column;gap:12px;backdrop-filter:blur(20px);"
                onmouseover="this.style.borderColor='rgba(10,132,255,0.4)';this.style.background='rgba(10,132,255,0.1)'"
                onmouseout="this.style.borderColor='rgba(255,255,255,0.1)';this.style.background='rgba(28,28,32,0.8)'">
                <div
                    style="width:44px;height:44px;background:rgba(10,132,255,0.2);border-radius:14px;display:flex;align-items:center;justify-content:center;">
                    <i class="material-icons" style="color:#0a84ff;">person</i>
                </div>
                <div>
                    <p style="margin:0;font-weight:700;color:#fff;font-size:1rem;">Mi Perfil</p>
                    <p style="margin:4px 0 0;font-size:0.82rem;color:rgba(255,255,255,0.4);">Ver y editar mis datos</p>
                </div>
            </a>

            <div
                style="background:rgba(28,28,32,0.8);border:1px solid rgba(255,255,255,0.1);border-radius:22px;padding:24px;display:flex;flex-direction:column;gap:12px;backdrop-filter:blur(20px);">
                <div
                    style="width:44px;height:44px;background:rgba(48,209,88,0.2);border-radius:14px;display:flex;align-items:center;justify-content:center;">
                    <i class="material-icons" style="color:#30d158;">verified_user</i>
                </div>
                <div>
                    <p style="margin:0;font-weight:700;color:#fff;font-size:1rem;">Estado de Cuenta</p>
                    <p style="margin:4px 0 0;font-size:0.82rem;color:#30d158;">✓ Activa y verificada</p>
                </div>
            </div>
        </div>

        <!-- Info card -->
        <div
            style="background:rgba(28,28,32,0.8);border:1px solid rgba(255,255,255,0.08);border-radius:24px;padding:24px;backdrop-filter:blur(20px);">
            <p
                style="font-size:0.75rem;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.1em;margin:0 0 16px;">
                Acceso</p>
            <div
                style="display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.07);">
                <div
                    style="width:34px;height:34px;background:rgba(88,86,214,0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="material-icons" style="font-size:1rem;color:#5856d6;">shield</i>
                </div>
                <div>
                    <p style="margin:0;font-size:0.9rem;color:rgba(255,255,255,0.5);">Rol asignado</p>
                    <p style="margin:2px 0 0;font-size:0.95rem;color:#fff;font-weight:600;">Usuario</p>
                </div>
            </div>
            <div style="display:flex;align-items:center;gap:12px;padding:12px 0;">
                <div
                    style="width:34px;height:34px;background:rgba(255,149,0,0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="material-icons" style="font-size:1rem;color:#ff9500;">info</i>
                </div>
                <div>
                    <p style="margin:0;font-size:0.9rem;color:rgba(255,255,255,0.5);">Nivel de acceso</p>
                    <p style="margin:2px 0 0;font-size:0.95rem;color:#fff;font-weight:600;">Estándar – acceso a perfil
                        propio</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (token) {
                try {
                    const payload = JSON.parse(atob(token.split('.')[1]));
                    if (payload.roles && payload.roles.includes('admin')) {
                        window.location.href = '/dashboard/admin';
                    }
                } catch (e) { }
            } else {
                window.location.href = '/signIn';
            }
        });
    </script>

    <%- include('partials/footer') %>