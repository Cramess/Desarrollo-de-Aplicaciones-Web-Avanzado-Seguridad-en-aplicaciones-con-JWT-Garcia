<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">

    <style>
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #000;
            background-image: radial-gradient(circle at 0% 0%, rgba(88, 86, 214, 0.4), transparent 50%),
                              radial-gradient(circle at 100% 100%, rgba(10, 132, 255, 0.3), transparent 50%);
            background-attachment: fixed;
            color: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        main {
            flex: 1 0 auto;
        }

        nav {
            background-color: transparent !important;
            box-shadow: none !important;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(25px) saturate(200%);
            -webkit-backdrop-filter: blur(25px) saturate(200%);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-wrapper {
            background-color: transparent !important;
        }

        .card.glassmorphism {
            background: rgba(30, 30, 35, 0.65);
            backdrop-filter: blur(25px) saturate(200%);
            -webkit-backdrop-filter: blur(25px) saturate(200%);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 28px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            overflow: hidden;
        }

        .card.glassmorphism .card-content {
            color: #fff;
            padding: 32px;
        }

        .card .card-title {
            font-weight: 700 !important;
            letter-spacing: -0.04em;
            font-size: 2.2rem !important;
            margin-bottom: 1.5rem !important;
        }

        /* iOS/OneUI Form Inputs */
        .input-field input[type=email],
        .input-field input[type=password],
        .input-field input[type=text] {
            color: #fff !important;
            background-color: rgba(255, 255, 255, 0.08) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            border-radius: 14px !important;
            padding: 0 16px !important;
            box-sizing: border-box !important;
            height: 3.2rem !important;
            box-shadow: none !important;
            transition: all 0.3s ease !important;
        }

        .input-field input:focus {
            background-color: rgba(255, 255, 255, 0.15) !important;
            border: 1px solid #0a84ff !important;
        }

        .input-field label {
            left: 16px !important;
            color: rgba(255, 255, 255, 0.5) !important;
        }

        .input-field .prefix {
            top: 0.6rem !important;
            left: 12px !important;
            color: rgba(255, 255, 255, 0.7);
        }

        .input-field .prefix ~ input {
            padding-left: 48px !important;
        }

        .input-field .prefix ~ label {
            margin-left: 32px !important;
        }

        /* Buttons */
        .btn-custom {
            background-color: #0a84ff;
            color: white;
            border-radius: 16px;
            height: 3.2rem;
            line-height: 3.2rem;
            text-transform: none;
            font-weight: 600;
            font-size: 1.1rem;
            letter-spacing: -0.01em;
            box-shadow: none;
            transition: all 0.2s ease;
        }

        .btn-custom:hover {
            background-color: #0070e0;
            box-shadow: none;
        }

        .btn-custom:active {
            transform: scale(0.96);
        }

        /* Tables */
        .table-custom {
            color: #fff;
            border-collapse: separate;
            border-spacing: 0 8px;
        }

        .table-custom th {
            color: rgba(255, 255, 255, 0.5);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: none;
            padding-bottom: 12px;
        }

        .table-custom td {
            background-color: rgba(255, 255, 255, 0.05);
            border-bottom: none;
            padding: 16px;
        }

        .table-custom tbody tr td:first-child {
            border-top-left-radius: 16px;
            border-bottom-left-radius: 16px;
        }

        .table-custom tbody tr td:last-child {
            border-top-right-radius: 16px;
            border-bottom-right-radius: 16px;
        }

        .modal {
            background-color: rgba(30, 30, 35, 0.85);
            backdrop-filter: blur(30px) saturate(200%);
            -webkit-backdrop-filter: blur(30px) saturate(200%);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 28px;
            color: #fff;
            box-shadow: 0 24px 40px rgba(0,0,0,0.5);
        }

        .modal .modal-footer {
            background-color: transparent;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .modal .modal-footer .btn-flat {
            color: #0a84ff !important;
            font-weight: 600;
            border-radius: 12px;
        }
    </style>
</head>

<body>
    <!-- Navbar iOS style -->
    <nav>
        <div class="nav-wrapper container" style="display:flex;align-items:center;justify-content:space-between; height:64px;">
            <a href="/" id="brand-logo" style="display:flex;align-items:center;gap:10px;font-weight:700;font-size:1.1rem;letter-spacing:-0.03em;color:#fff;text-decoration:none;">
                <span style="width:34px;height:34px;background:linear-gradient(135deg,#5856d6,#0a84ff);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                    <i class="material-icons" style="font-size:1.1rem;color:#fff;">lock</i>
                </span>
                AuthApp
            </a>
            <ul style="display:flex;align-items:center;gap:4px;list-style:none;margin:0;padding:0;">
                <li id="nav-login"><a href="/signIn" class="nav-pill">Iniciar Sesión</a></li>
                <li id="nav-register"><a href="/signUp" class="nav-pill nav-pill-primary">Registrarse</a></li>
                <li id="nav-dashboard" style="display:none;"><a href="#" id="link-dashboard" class="nav-pill">Dashboard</a></li>
                <li id="nav-profile" style="display:none;"><a href="/profile" class="nav-pill">Mi Cuenta</a></li>
                <li id="nav-logout" style="display:none;"><a href="#" onclick="logout()" class="nav-pill nav-pill-danger">Cerrar Sesión</a></li>
            </ul>
        </div>
    </nav>

    <style>
        .nav-pill {
            display: inline-block;
            padding: 7px 16px;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 500;
            color: rgba(255,255,255,0.85) !important;
            background: rgba(255,255,255,0.08);
            transition: all 0.2s ease;
            text-decoration: none;
        }
        .nav-pill:hover {
            background: rgba(255,255,255,0.14);
            color: #fff !important;
        }
        .nav-pill-primary {
            background: #0a84ff !important;
            color: #fff !important;
        }
        .nav-pill-primary:hover {
            background: #0070e0 !important;
        }
        .nav-pill-danger {
            background: rgba(255, 69, 58, 0.2) !important;
            color: #ff453a !important;
        }
        .nav-pill-danger:hover {
            background: rgba(255, 69, 58, 0.3) !important;
        }
    </style>

    <main class="container" style="padding-top: 24px;">